# M3 Memory: Interactive Shell Configuration (.zshrc)
# This file should be copied to ~/.zshrc.
# It depends on variables loaded from ~/.zshenv, especially $M3_MEMORY_ROOT.

# --- 1. HISTORY & COMPLETION ---
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory sharehistory hist_ignore_all_dups hist_save_no_dups

autoload -Uz compinit && compinit
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# --- 2. CORE ALIASES (Modern Tools) ---
# These are recommended for a better terminal experience.
# Install with: brew install eza bat
alias ll='eza -lh --git --group-directories-first -s extension --icons'
alias la='eza -alh --git --group-directories-first --icons'
alias cat='bat --style=plain --paging=never'

# --- 3. AGENT OS ALIASES & FUNCTIONS ---
# These rely on $M3_MEMORY_ROOT being set in .zshenv

# Check if M3_MEMORY_ROOT is set
if [ -z "$M3_MEMORY_ROOT" ] || [ ! -d "$M3_MEMORY_ROOT" ]; then
    echo "Warning: \$M3_MEMORY_ROOT is not set or is not a valid directory." >&2
    echo "Please set it in your ~/.zshenv file." >&2
else
    # Core Tools
    alias pulse='python3 $M3_MEMORY_ROOT/bin/mission_control.py'
    alias ai-audit='$M3_MEMORY_ROOT/bin/ai-audit.sh'
    alias chroma-sync='python3 $M3_MEMORY_ROOT/bin/chroma_sync_cli.py'
    alias mcp-check='$M3_MEMORY_ROOT/bin/mcp_check.sh'

    # Aider Functions (with dynamic path)
    # These functions call aider with the correct project-specific configuration.
    _run_aider() {
        local model_flag="$1"
        shift
        aider --config "$M3_MEMORY_ROOT/.aider.conf.yml" 
              --model-metadata-file "$M3_MEMORY_ROOT/.aider.model.metadata.json" 
              "$model_flag" "$@"
    }

    function aider-grok { _run_aider "--model xai/grok-3-latest" "$@"; }
    function aider-claude { _run_aider "--model claude-3-5-sonnet-20241022" "$@"; }
    function aider-gemini { _run_aider "--model gemini/gemini-2-0-flash-exp" "$@"; }

    # OpenClaw Sandbox Management
    _OPENCLAW_SANDBOX="$M3_MEMORY_ROOT/sandbox-openclaw"

    _claw_switch() {
        # This is a simplified helper for switching OpenClaw models.
        # It assumes docker is running and .env has been populated by .zshenv
        (cd "$_OPENCLAW_SANDBOX" && docker compose up -d --quiet-pull >/dev/null 2>&1)
        echo "OpenClaw Sandbox: Switched to $3"
        echo "  Dashboard: http://localhost:8000/?token=${OPENCLAW_GATEWAY_TOKEN}"
    }

    function claw-grok { _claw_switch "xai/grok-3" "xai:default" "Grok"; }
    function claw-claude { _claw_switch "anthropic/claude-sonnet-4-6" "anthropic:default" "Claude"; }
    function claw-gemini { _claw_switch "google/gemini-2.0-flash-exp" "google:default" "Gemini"; }
    function claw-local { _claw_switch "openai/deepseek-r1-distill-llama-70b-mlx" "openai:lmstudio" "Local LLM"; }
    
    function de-claw {
        echo "Shutting down OpenClaw sandbox..."
        (cd "$_OPENCLAW_SANDBOX" && docker compose down)
        echo "Sandbox shut down."
    }
fi

# --- 4. SHELL PLUGINS & PROMPT ---
# Install with: brew install zsh-autosuggestions zsh-syntax-highlighting fzf

# FZF (Fuzzy Finder)
if command -v fzf &> /dev/null; then
  source <(fzf --zsh)
fi

# Zsh Plugins (assumes Homebrew installation path)
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Custom Prompt
PROMPT=$'
%h! %(#.%F{red}.%F{magenta})%n%f@%F{yellow}%m%f:%~%(#.%F{yellow} # .%F{white} %% )%f'
