      ]
    },
    "memory": {
      "command": "python",
      "args": [
        "[M3_MEMORY_ROOT]/bin/memory_bridge.py"
      ]
    },
    "grok_intel": {
      "command": "python",
      "args": [
        "[M3_MEMORY_ROOT]/bin/grok_bridge.py"
      ]
    },
    "web_research": {
      "command": "python",
      "args": [
        "[M3_MEMORY_ROOT]/bin/web_research_bridge.py"
      ]
    },
    "debug_agent": {
      "command": "python",
      "args": [
