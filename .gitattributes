# Keep shell scripts + Python as LF on all platforms so Linux/macOS hook
# execution isn't broken by Windows CRLF on a mixed-OS checkout.
# Text files normalize to LF in the repo; native line endings in the
# working tree are left to git's autocrlf default.
*.sh       text eol=lf
*.py       text eol=lf
*.ps1      text eol=crlf
# Generated SVGs (e.g. docs/star-history.svg) are byte-compared by their
# generator to avoid spurious commits — pin LF so the committed file matches
# what the generator writes on any runner, regardless of core.autocrlf.
*.svg      text eol=lf

# The homelab-dashboard icon cache holds RUNTIME-FETCHED icon blobs, some of
# which are PNGs saved with a .svg extension (magic bytes 89 50 4E 47). The
# `*.svg text eol=lf` rule above would try to LF-normalize those binaries,
# mangling a byte on every checkout — leaving them permanently "modified" and
# breaking stash pop / merge / checkout. Force the whole cache dir to binary so
# git never applies eol conversion to it (it's a cache, not source).
examples/homelab-dashboard/backend/cache/** binary

# Git hooks are extensionless shell scripts — must stay LF so they execute
# on Linux/macOS after a Windows checkout.
.githooks/* text eol=lf

# Binaries: never convert.
*.db       binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.ico      binary
*.gguf     binary

# GGUF model assets under _assets/models/ are tracked via Git LFS — they're
# hundreds of MB each. Cloning without LFS yields a small pointer file;
# `git lfs pull` materializes the real bytes. `m3 embedder install` detects
# unmaterialized pointers and prints actionable guidance.
_assets/models/*.gguf filter=lfs diff=lfs merge=lfs -text
*.tar.gz   binary
*.zip      binary
