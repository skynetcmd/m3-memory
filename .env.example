# M3 Memory: Example Environment
# Copy this to .env and fill in your local values.
PROJECT_ROOT=
SYNC_TARGET_IP=YOUR_SERVER_IP
POSTGRES_SERVER=YOUR_SERVER_IP
CHROMA_BASE_URL=http://YOUR_SERVER_IP:8000
EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# Secrets like API keys and PG_URL should be stored in your OS keychain.
# Use bin/auth_utils.py to set them, e.g.:
# python3 bin/auth_utils.py set PG_URL "postgresql://user:pass@host:port/dbname"
