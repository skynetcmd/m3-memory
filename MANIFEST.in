# Attribution: the Apache LICENSE + NOTICE (attribution to skynetCMD) ship in
# the sdist. license-files in pyproject.toml also packages them into the wheel.
include LICENSE
include NOTICE

# Ship the vendored Hermes Agent memory-provider plugin in the sdist. (In the
# wheel it's carried as package-data; see [tool.setuptools.package-data] for
# m3_memory in pyproject.toml.) The setup wizard's _find_m3_hermes_plugin_src()
# resolves it under m3_memory/integrations/hermes/.
graft m3_memory/integrations/hermes

# Ship the runnable PAYLOAD in the wheel so a `pipx install m3-memory` user with
# no repo clone (and possibly air-gapped) gets the full toolset — no `install-m3`
# GitHub fetch required. These root-level trees are mapped INTO the package via
# [tool.setuptools.force-include] in pyproject.toml so they land under
# m3_memory/ in the installed package; installer.py resolves them from there
# (or from their per-component $M3_PATH_* override). Keeping them at repo root
# (not physically moving them under m3_memory/) avoids churning the whole
# bin/... reference surface.
graft bin
graft docs
graft _assets
graft examples
include install_os.py
recursive-include memory/migrations *.sql

global-exclude __pycache__/*
global-exclude *.py[cod]
global-exclude *.pdb

# Prune colocated hermetic tests (e.g. integrations/langchain/test_provider_logic.py)
# from BOTH the sdist and the wheel. Verified against an ISOLATED release build
# (`python -m build`, which fetches the pinned setuptools>=77,<82): the resulting
# wheel contains 0 test_*.py. (A non-isolated build using a newer local setuptools
# — e.g. 82.x, outside our pin — can ignore this exclude for wheel package modules,
# so always validate packaging with an isolated build, not the dev setuptools.)
global-exclude test_*.py
