# OpenClaw Sandbox Environment
# Copy to .env and fill in your values

# -- Core MCP Bridge Settings --
# These must match your main ~/m3-memory/.env settings
# The Docker container needs them to reach the host OS bridges.
SYNC_TARGET_IP=YOUR_SERVER_IP
POSTGRES_SERVER=YOUR_SERVER_IP
CHROMA_BASE_URL=http://YOUR_SERVER_IP:8000
PG_URL=postgresql://agent_os:YOUR_SECURE_PASSWORD@YOUR_SERVER_IP:5432/agent_memory

# -- API Keys (resolved from keychain if not set) --
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# PERPLEXITY_API_KEY=
# X_API_KEY=
