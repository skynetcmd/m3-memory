<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.homelab.dashboard</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>[M3_MEMORY_ROOT]/homelab-dashboard/start_dashboard.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>[M3_MEMORY_ROOT]/homelab-dashboard/backend/dashboard.log</string>
    <key>StandardErrorPath</key>
    <string>[M3_MEMORY_ROOT]/homelab-dashboard/backend/dashboard_error.log</string>
</dict>
</plist>