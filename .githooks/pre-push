#!/usr/bin/env bash
# Shared pre-push hook — runs for EVERY agent (Claude / Gemini / Antigravity)
# and human, independent of which AGENTS instruction file they read. Enable
# once per clone:  git config core.hooksPath .githooks
# (or run: python bin/setup_hooks.py)
#
# Enforces the two mechanical halves of the pre-push process from
# docs/AGENT_INSTRUCTIONS.md:
#   1. Tool-catalog / generated-docs drift gate.
#   2. Bench-data leakage scan on the outgoing diff.
#
# A non-zero exit blocks the push. Override only in a real emergency with
# `git push --no-verify` — and then fix forward immediately.
#
# Performance: the expensive half is the drift gate, which spawns Python to
# regenerate artifacts + run pytest. That work is only meaningful when the
# push actually touches the tool catalog, its generators, or the docs whose
# counts they own. So we change-detect first and SKIP the gate entirely when
# the push range doesn't touch those paths — the common case. The leakage
# scan is a sub-millisecond `git diff | grep` and always runs.

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

PY="python"
command -v python >/dev/null 2>&1 || PY="python3"

# --- Determine the exact push range -----------------------------------------
# git feeds the pre-push hook one line per ref on stdin:
#   <local ref> <local sha> <remote ref> <remote sha>
# Using the real remote sha makes both the change-detection and the leakage
# scan precise — we inspect exactly the commits this push would publish, not a
# hardcoded origin/main guess that's wrong for feature branches / other remotes.
ZERO="0000000000000000000000000000000000000000"
RANGES=()
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$ZERO" ] && continue          # branch deletion — nothing to scan
  if [ "$remote_sha" = "$ZERO" ]; then
    RANGES+=("$local_sha")                         # new remote branch — scan all of it
  else
    RANGES+=("$remote_sha..$local_sha")            # existing branch — only new commits
  fi
done

# Fallback when stdin is empty (e.g. invoked manually for a dry run): use the
# old origin/main heuristic so the gate still does something sensible.
if [ ${#RANGES[@]} -eq 0 ]; then
  if git rev-parse --verify --quiet origin/main >/dev/null; then
    RANGES=("origin/main..HEAD")
  else
    RANGES=("HEAD")
  fi
fi

# Union of files changed across all pushed ranges.
changed_files() {
  local r
  for r in "${RANGES[@]}"; do
    git diff --name-only "$r" 2>/dev/null || true
  done | sort -u
}
CHANGED="$(changed_files)"

# --- 1/3 tool-catalog drift gate (conditional) ------------------------------
# Paths whose change can make the generated catalog/inventory or the hardcoded
# "N tools" counts go stale. Mirrors check_tool_catalog_drift.py's universe.
if printf '%s\n' "$CHANGED" | grep -qE \
  '^bin/mcp_tool_catalog\.py$|^bin/mcp_proxy\.py$|^bin/gen_tool_manifest\.py$|^bin/gen_mcp_inventory\.py$|^docs/tools/MCP_CATALOG\.json$|^docs/MCP_TOOLS\.md$|^README\.md$|^docs/COMPARISON\.md$|^docs/MYTHS_AND_FACTS\.md$|^docs/tools/files_memory\.md$|^tests/test_tool_count_drift\.py$|^tests/test_mcp_catalog_manifest_fresh\.py$'
then
  echo "[pre-push] 1/3 tool-catalog drift gate (catalog/docs touched — checking)"
  "$PY" bin/check_tool_catalog_drift.py || {
    echo "[pre-push] BLOCKED: tool-catalog drift. Regenerate + commit, then re-push." >&2
    exit 1
  }
else
  echo "[pre-push] 1/3 tool-catalog drift gate — skipped (no catalog/doc paths in push)"
fi

# --- 2/3 shim re-export integrity gate (conditional) ------------------------
# The memory_core modularization is a FACADE: bin/memory/*.py re-export symbols
# from each other, and downstream does `from memory.embed import <sym>`. A
# re-exported symbol has no direct caller in its own module, so `ruff --fix`'s
# unused-import autofix silently STRIPS it — breaking the import chain at RUNTIME,
# not at lint time (memory_write broke this way in 4d46b97). Run the shim guard
# whenever a memory shim file changes so a stripped re-export can't reach the
# remote.
if printf '%s\n' "$CHANGED" | grep -qE '^bin/memory/[a-z_]+\.py$|^bin/memory_core\.py$'
then
  echo "[pre-push] 2/3 shim re-export integrity gate (memory shim touched — checking)"
  "$PY" -m pytest tests/test_shim_reexports.py -q >/dev/null 2>&1 || {
    echo "[pre-push] BLOCKED: a memory shim re-export is missing (likely stripped" >&2
    echo "  by 'ruff --fix'). Run: pytest tests/test_shim_reexports.py -q" >&2
    echo "  Restore the dropped 'from .<sibling> import ...' + mark it # noqa: F401." >&2
    exit 1
  }
else
  echo "[pre-push] 2/3 shim re-export integrity gate — skipped (no memory shim in push)"
fi

# --- 3/3 bench-data + compromising-content leakage scan (always) ------------
# Patterns mirror the m3 bench-privacy guard (LME-M ids, dataset paths, local
# absolute paths, credentials) PLUS "don't leak anything compromising":
#   - generic RFC1918 IP SHAPES (10.x / 192.168.x) — catches any internal IP
#     without hardcoding the user's specific subnet (placeholders like 10.x.x.x
#     don't match — x is not a digit). Specific homelab values live in the
#     box-only gitleaks config on the scanner, never in this tracked file.
#   - generic MAC-address shape, the internal-schema-fork planning doc, and
#     bench-schema phrases.
# A hit is a STOP — investigate before pushing. Exclude the meta-files that
# legitimately CONTAIN the marker patterns: this hook (its own regex), the
# process docs, and the leakage-test fixtures — else the scanner matches its
# own definition (a false positive blocking the very commit that adds the gate).
echo "[pre-push] 3/3 bench-data + compromising-content leakage scan"
LEAK=""
for r in "${RANGES[@]}"; do
  # Only scan addition lines (^+) — deletions can't leak to the remote.
  # Exclude the +++ file header lines to avoid false matches on file paths.
  hit="$(git diff "$r" -- '**' \
    ':(exclude).githooks/pre-push' \
    ':(exclude).gitignore' \
    ':(exclude)docs/AGENT_INSTRUCTIONS.md' \
    ':(exclude)docs/SUB_6_7_KICKOFF.md' \
    ':(exclude)tests/test_*leak*' \
    ':(exclude)tests/test_*bench*' \
    2>/dev/null | grep '^+' | grep -v '^+++' | grep -iE \
    'lme-m/v3|lme_m\.db|PLAN_v4|smoke-142|237,655|2,446,993|enrichment_groups.*lme|locomo[_-]runs|/Users/[a-z]+|C:[\\/]+Users|/home/[a-z]+/|@gmail|sk-ant-[a-z0-9]{20,}|AIza[a-z0-9_-]{30,}|\b10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\b|\b192\.168\.[0-9]{1,3}\.[0-9]{1,3}\b|SCHEMA_MIGRATION_FORK|bench[ -]schema|leak bench' \
    || true)"
  [ -n "$hit" ] && LEAK="$LEAK$hit"$'\n'
done
if [ -n "$LEAK" ]; then
  echo "[pre-push] BLOCKED: possible bench-data / secret leakage in the push diff:" >&2
  echo "$LEAK" | head -20 >&2
  echo "[pre-push] Investigate before pushing (see CLAUDE.md / AGENT_INSTRUCTIONS.md bench-data rules)." >&2
  exit 1
fi

# Design-philosophy reminder — only when this push actually changes code
# (bin/ or m3_memory/ .py), not on docs/config-only pushes. The author is
# responsible for following the guidelines; this is a prompt, not a tool or a
# gate (no auto-checking, nothing to bypass). Uses the already-computed
# CHANGED union (across all pushed ranges) rather than a single $RANGE diff,
# so it's accurate for multi-ref / non-origin pushes too.
CODE_CHANGED="$(printf '%s\n' "$CHANGED" | grep -E '^(bin/|m3_memory/).*\.py$' || true)"
if [ -n "$CODE_CHANGED" ]; then
  cat >&2 <<'REMINDER'
[pre-push] Design philosophies — hold these as you push (docs/DESIGN_PHILOSOPHIES.md):
   - Effectiveness (§5): does it move a pre-registered metric? "It compiles" is the floor.
   - Robustness (§3): fail loud, structured returns, empty=zero/list never None.
   - Efficiency (§4) / Performance (§8): SQL not Python aggregation; meet P50/P95/P99 budgets.
   - Hardening (§6) / Privacy (§7): parameterized SQL, gated destructive ops, scope on every query.
   - Modularity (§2): one feature per PR; shim-preserved identity.
   - Tool-shape (§12): returns are an API surface — give agents rows, not prose.
   Full text: docs/DESIGN_PHILOSOPHIES.md (re-read §2-§8 before adding a tool/submodule/impl fn).
REMINDER
fi

echo "[pre-push] OK — drift clean, no leakage detected."
